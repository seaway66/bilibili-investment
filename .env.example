# 视觉模型 API Key（至少配置一个）
GLM_API_KEY=your_glm_api_key_here        # 智谱 GLM-4.6V-Flash（免费，推荐）
DASHSCOPE_API_KEY=your_qwen_api_key_here  # 千问 qwen-vl-max（付费兜底，可选）

# 可选配置
VISION_PROVIDER=glm                       # 默认视觉供应商 (glm/qwen/openai/doubao)
VISION_MAX_TOKENS=4096                    # 视觉模型最大输出 tokens
